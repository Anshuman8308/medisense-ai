# ─────────────────────────────────────────────────────────────────────────────
# MediSense AI v2 — Environment Configuration
# Copy this file:  cp .env.example .env
# Then fill in the values below.
# NEVER commit your real .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=development           # development | production
FLASK_DEBUG=true                # set false in production
PORT=5000
SECRET_KEY=change-me-to-a-long-random-string

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Use * for development; restrict to your deployed frontend URL in production.
CORS_ORIGINS=*
# CORS_ORIGINS=https://medisense.vercel.app,https://www.yoursite.com

# ── Google Maps API ───────────────────────────────────────────────────────────
# Required for real nearby-doctor search and map display.
# Get a key at: https://console.cloud.google.com/
# Enable: Places API, Maps JavaScript API, Directions API
GOOGLE_MAPS_API_KEY=

# ── Anthropic / Claude API ────────────────────────────────────────────────────
# Optional: used to power the conversational chat with Claude instead of
# rule-based responses. Get a key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Optional: enables persistent prediction history and user accounts.
# Local:  mongodb://localhost:27017/medisense
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/medisense
MONGO_URI=mongodb://localhost:27017/medisense

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT=60 per minute
